    {
      "parameters": {
        "jsCode": "const preparedCalendars = $('Prepare Calendars').all();\nconst responses = $input.all();\nconst bracket = $('Store Bracket').first().json;\n\nconst people = responses.map((response, i) => {\n  const cal = preparedCalendars[i];\n  const personName = cal ? cal.json.personName : `calendar_${i}`;\n  // Filter out cancelled events; any remaining event means the person is busy\n  const events = (response.json.items || []).filter(e => e.status !== 'cancelled');\n  return {\n    name: personName,\n    available: events.length === 0\n  };\n});\n\nreturn [{\n  json: {\n    lower: bracket.lower,\n    upper: bracket.upper,\n    displayLower: bracket.displayLower,\n    displayUpper: bracket.displayUpper,\n    people,\n    allAvailable: people.every(p => p.available)\n  }\n}];"
      },
