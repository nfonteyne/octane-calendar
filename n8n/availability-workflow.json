    {
      "parameters": {
        "jsCode": "const brackets = [];\n\nlet current_date = DateTime.now().setZone('Europe/Paris');\nlet end_date = current_date.plus({ day: 21 });\n\ndo {\n  let setLower, setUpper;\n\n  if (current_date.weekday < 6) {\n    setLower = { hour: 18, minute: 30 };\n    setUpper = { hour: 21, minute: 0 };\n  } else {\n    setLower = { hour: 15, minute: 0 };\n    setUpper = { hour: 19, minute: 0 };\n  }\n\n  const lower = current_date.set(setLower);\n  const upper = current_date.set(setUpper);\n\n  brackets.push({\n    json: {\n      lower: lower.toISO(),\n      upper: upper.toISO(),\n      displayLower: lower.plus({ minutes: 30 }).toISO(),\n      displayUpper: upper.minus({ minutes: 30 }).toISO()\n    }\n  });\n\n  current_date = current_date.plus({ day: 1 });\n} while (current_date <= end_date);\n\nreturn brackets;"
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Set date brackets",
