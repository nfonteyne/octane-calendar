    {
      "parameters": {
        "jsCode": "const bracket = $('Store Bracket').first().json;\nconst lower = bracket.lower;\nconst upper = bracket.upper;\n\nif (!lower || !upper) {\n  throw new Error('lower/upper are missing from Store Bracket node');\n}\n\nconst summaryToName = {\n  'calendrier travail nathan': 'Nathan',\n  'nathan.fonteyne59@gmail.com': 'Nathan',\n  'nathan & estelle': 'Nathan',\n  'benoitgeorge89@gmail.com': 'Raphaël',\n  'agenda yann': 'Yann',\n  'jules.vayre@gmail.com': 'Jules',\n  'calendrier ak': 'AK',\n};\n\nreturn $input.all().map(cal => {\n  const id = cal.json.id;\n  const summary = (cal.json.summaryOverride || cal.json.summary || '').trim().toLowerCase();\n  return {\n    json: {\n      calendarId: encodeURIComponent(id),\n      personName: summaryToName[summary] || summary,\n      lower,\n      upper,\n    }\n  };\n});"
      },
