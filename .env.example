# URL of the n8n webhook that checks availability
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/calendar-availability

# Basic-auth credentials configured on the n8n webhook node
N8N_WEBHOOK_USER=your_username
N8N_WEBHOOK_PASS=your_password

# Port the web app listens on (default: 3000)
PORT=3000
